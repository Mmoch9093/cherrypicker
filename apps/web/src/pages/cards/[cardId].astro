---
import Layout from '../../layouts/Layout.astro';
import CardDetail from '../../components/cards/CardDetail.svelte';
import { readFile } from 'fs/promises';
import { resolve } from 'path';

export async function getStaticPaths() {
  const dataPath = resolve(process.cwd(), 'public/data/cards.json');
  const raw = await readFile(dataPath, 'utf-8');
  const data = JSON.parse(raw) as { issuers: Array<{ cards: Array<{ card: { id: string } }> }> };
  return data.issuers.flatMap(issuer =>
    issuer.cards.map(card => ({ params: { cardId: card.card.id } }))
  );
}

const { cardId } = Astro.params;
const base = import.meta.env.BASE_URL;
---

<Layout title="카드 상세">
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="mb-6">
    <ol class="flex flex-wrap items-center gap-1.5 text-sm text-[var(--color-text-muted)]">
      <li>
        <a href={`${base}`} class="transition-colors hover:text-[var(--color-primary)]">홈</a>
      </li>
      <li class="select-none text-[var(--color-border)]">/</li>
      <li>
        <a href={`${base}cards`} class="transition-colors hover:text-[var(--color-primary)]">카드 목록</a>
      </li>
      <li class="select-none text-[var(--color-border)]">/</li>
      <li class="font-medium text-[var(--color-text)]" aria-current="page" id="breadcrumb-card-name">
        {cardId}
      </li>
    </ol>
  </nav>

  <!-- Card detail -->
  <div class="animate-[slideUp_0.4s_ease_both]">
    <CardDetail cardId={cardId} client:load />
  </div>
</Layout>
